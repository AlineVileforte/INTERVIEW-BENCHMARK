  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-NL1</outgoing>
    </startEvent>
    <task id="NL1" name="Nico ist langweilig">
      <incoming>Default_init-NL1</incoming>
      <outgoing>NL1-G0</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>NL1-G0</incoming>
      <outgoing>G0-NH1</outgoing>
      <outgoing>G0-G1</outgoing>
    </exclusiveGateway>
    <task id="NH1" name="Nico hat Hunger">
      <incoming>G0-NH1</incoming>
      <outgoing>NH1-NIB1</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>G0-G1</incoming>
      <outgoing>G1-NWF1</outgoing>
      <outgoing>G1-NUL1</outgoing>
    </exclusiveGateway>
    <task id="NIB1" name="Nico isst eine Banane">
      <incoming>NH1-NIB1</incoming>
      <outgoing>NIB1-XORCLOSE10</outgoing>
    </task>
    <task id="NWF1" name="Nico will fischen">
      <incoming>G1-NWF1</incoming>
      <outgoing>NWF1-NGF1</outgoing>
    </task>
    <task id="NUL1" name="Nico hat unbändige Lust">
      <incoming>G1-NUL1</incoming>
      <outgoing>NUL1-NSFF1</outgoing>
    </task>
    <task id="NGF1" name="Nico geht fischen">
      <incoming>NWF1-NGF1</incoming>
      <outgoing>NGF1-XORCLOSE9</outgoing>
    </task>
    <task id="NSFF1" name="Nico schaut funny Filmchen">
      <incoming>NUL1-NSFF1</incoming>
      <outgoing>NSFF1-XORCLOSE9</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE9" name="XORCLOSE9">
      <incoming>NGF1-XORCLOSE9</incoming>
      <incoming>NSFF1-XORCLOSE9</incoming>
      <outgoing>XORCLOSE9-XORCLOSE10</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XORCLOSE10" name="XORCLOSE10">
      <incoming>NIB1-XORCLOSE10</incoming>
      <incoming>XORCLOSE9-XORCLOSE10</incoming>
      <outgoing>XORCLOSE10-NG1</outgoing>
    </exclusiveGateway>
    <task id="NG1" name="Nico ist glücklich">
      <incoming>XORCLOSE10-NG1</incoming>
      <outgoing>NG1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>NG1-END</incoming>
    </endEvent>
