    </exclusiveGateway>
    <task id="PTG1" name="Pack the Goods">
      <incoming>GRD1-PTG1</incoming>
      <outgoing>PTG1-DTG1</outgoing>
    </task>
    <task id="DM1" name="Declining Message">
