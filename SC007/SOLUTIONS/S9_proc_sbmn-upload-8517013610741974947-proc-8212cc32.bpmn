      <incoming>Par7-G1</incoming>
      <outgoing>G1-DM1</outgoing>
      <outgoing>G1-CNC1</outgoing>
    </exclusiveGateway>
    <task id="CNC1" name="Create New Customer">
      <incoming>G1-CNC1</incoming>
      <outgoing>CNC1-XORCLOSE19</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE11" name="XORCLOSE11">
