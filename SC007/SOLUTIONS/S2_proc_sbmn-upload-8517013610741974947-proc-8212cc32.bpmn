  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-CC1</outgoing>
    </startEvent>
    <task id="CC1" name="Check Customer">
      <incoming>Default_init-CC1</incoming>
      <outgoing>CC1-SCC1</outgoing>
    </task>
    <task id="SCC1" name="Sending Confirmation to Customer">
      <incoming>CC1-SCC1</incoming>
      <outgoing>SCC1-G1</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>SCC1-G1</incoming>
      <outgoing>G1-CPH1</outgoing>
      <outgoing>G1-CCT1</outgoing>
    </exclusiveGateway>
    <task id="CPH1" name="Check Payment History">
      <incoming>G1-CPH1</incoming>
      <outgoing>CPH1-XORCLOSE6</outgoing>
    </task>
    <task id="CCT1" name="Check Customer Type">
      <incoming>G1-CCT1</incoming>
      <outgoing>CCT1-XORCLOSE6</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE6" name="XORCLOSE6">
      <incoming>CPH1-XORCLOSE6</incoming>
      <incoming>CCT1-XORCLOSE6</incoming>
      <outgoing>XORCLOSE6-Par7</outgoing>
    </exclusiveGateway>
    <parallelGateway id="Par7" name="PAR">
      <incoming>XORCLOSE6-Par7</incoming>
      <outgoing>Par7-GRD1</outgoing>
      <outgoing>Par7-G2</outgoing>
    </parallelGateway>
    <task id="GRD1" name="Getting ready for delivery">
      <incoming>Par7-GRD1</incoming>
      <outgoing>GRD1-PTG1</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
      <incoming>Par7-G2</incoming>
      <outgoing>G2-CNC1</outgoing>
      <outgoing>G2-DM1</outgoing>
    </exclusiveGateway>
    <task id="CNC1" name="Create New Customer">
      <incoming>G2-CNC1</incoming>
      <outgoing>CNC1-XORCLOSE16</outgoing>
    </task>
    <task id="PTG1" name="Pack the Goods">
      <incoming>GRD1-PTG1</incoming>
      <outgoing>PTG1-DTG1</outgoing>
    </task>
    <task id="DTG1" name="Deliver the Goods">
      <incoming>PTG1-DTG1</incoming>
      <outgoing>DTG1-PI1</outgoing>
    </task>
    <task id="DM1" name="Declining Message">
      <incoming>G2-DM1</incoming>
      <outgoing>DM1-XORCLOSE16</outgoing>
    </task>
    <task id="PI1" name="Preparing Invoice">
      <incoming>DTG1-PI1</incoming>
      <outgoing>PI1-SIC1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE16" name="XORCLOSE16">
