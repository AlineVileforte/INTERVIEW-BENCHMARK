    <exclusiveGateway id="G4" name="G4">
      <incoming>XOR_JMPAA_CTR1_CFP1-G4</incoming>
      <outgoing>G4-DP1</outgoing>
      <outgoing>G4-XORCLOSE29</outgoing>
    </exclusiveGateway>
    <task id="DP1" name="Dunning Process">
      <incoming>G4-DP1</incoming>
      <outgoing>DP1-XORCLOSE29</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE29" name="XORCLOSE29">
      <incoming>G4-XORCLOSE29</incoming>
      <incoming>DP1-XORCLOSE29</incoming>
      <outgoing>XORCLOSE29-XORCLOSE30</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XORCLOSE30" name="XORCLOSE30">
      <incoming>CO1-XORCLOSE30</incoming>
      <incoming>XORCLOSE29-XORCLOSE30</incoming>
      <outgoing>XORCLOSE30-END</outgoing>
    </exclusiveGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>XORCLOSE30-END</incoming>
    </endEvent>
    <exclusiveGateway id="XOR_JMPAA_CTR1_CFP1" name="XOR_JMPAA_Checking the reminders">
      <incoming>CTR1-XOR_JMPAA_CTR1_CFP1</incoming>
      <outgoing>XOR_JMPAA_CTR1_CFP1-G4</outgoing>
      <outgoing>XOR_JMPAA_CTR1_CFP1-XOR_JMPBB_CTR1_CFP1</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XOR_JMPBB_CTR1_CFP1" name="XOR_JMPBB_Check for Payment">
      <incoming>SIC1-XOR_JMPBB_CTR1_CFP1</incoming>
      <incoming>XOR_JMPAA_CTR1_CFP1-XOR_JMPBB_CTR1_CFP1</incoming>
      <outgoing>XOR_JMPBB_CTR1_CFP1-CFP1</outgoing>
    </exclusiveGateway>
