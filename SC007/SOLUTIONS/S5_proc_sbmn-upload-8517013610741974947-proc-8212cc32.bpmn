  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-CC1</outgoing>
    </startEvent>
    <task id="CC1" name="Check Customer">
      <incoming>Default_init-CC1</incoming>
      <outgoing>CC1-G0</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>CC1-G0</incoming>
      <outgoing>G0-CPH1</outgoing>
      <outgoing>G0-CCT1</outgoing>
    </exclusiveGateway>
    <task id="CPH1" name="Check Payment History">
      <incoming>G0-CPH1</incoming>
      <outgoing>CPH1-XORCLOSE5</outgoing>
    </task>
    <task id="CCT1" name="Check Customer Type">
      <incoming>G0-CCT1</incoming>
      <outgoing>CCT1-XORCLOSE5</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE5" name="XORCLOSE5">
      <incoming>CPH1-XORCLOSE5</incoming>
      <incoming>CCT1-XORCLOSE5</incoming>
      <outgoing>XORCLOSE5-G1</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="G1" name="G1">
      <incoming>XORCLOSE5-G1</incoming>
      <outgoing>G1-CNC1</outgoing>
      <outgoing>G1-DM1</outgoing>
    </exclusiveGateway>
    <task id="CNC1" name="Create New Customer">
      <incoming>G1-CNC1</incoming>
      <outgoing>CNC1-XORCLOSE10</outgoing>
    </task>
    <task id="DM1" name="Declining Message">
      <incoming>G1-DM1</incoming>
      <outgoing>DM1-XORCLOSE10</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE10" name="XORCLOSE10">
      <incoming>CNC1-XORCLOSE10</incoming>
      <incoming>DM1-XORCLOSE10</incoming>
      <outgoing>XORCLOSE10-CA1</outgoing>
    </exclusiveGateway>
    <task id="CA1" name="Check Availability">
      <incoming>XORCLOSE10-CA1</incoming>
      <outgoing>CA1-G2</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
      <incoming>CA1-G2</incoming>
      <outgoing>G2-PMG1</outgoing>
      <outgoing>G2-XORCLOSE15</outgoing>
    </exclusiveGateway>
    <task id="PMG1" name="Producing Missing Goods">
      <incoming>G2-PMG1</incoming>
      <outgoing>PMG1-XORCLOSE15</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE15" name="XORCLOSE15">
      <incoming>G2-XORCLOSE15</incoming>
      <incoming>PMG1-XORCLOSE15</incoming>
      <outgoing>XORCLOSE15-SCC1</outgoing>
    </exclusiveGateway>
    <task id="SCC1" name="Sending Confirmation to Customer">
      <incoming>XORCLOSE15-SCC1</incoming>
      <outgoing>SCC1-GRD1</outgoing>
    </task>
    <task id="GRD1" name="Getting ready for delivery">
      <incoming>SCC1-GRD1</incoming>
      <outgoing>GRD1-PTG1</outgoing>
    </task>
    <task id="PTG1" name="Pack the Goods">
      <incoming>GRD1-PTG1</incoming>
      <outgoing>PTG1-DTG1</outgoing>
    </task>
    <task id="DTG1" name="Deliver the Goods">
      <incoming>PTG1-DTG1</incoming>
      <outgoing>DTG1-PI1</outgoing>
    </task>
    <task id="PI1" name="Preparing Invoice">
      <incoming>DTG1-PI1</incoming>
      <outgoing>PI1-SIC1</outgoing>
    </task>
    <task id="SIC1" name="Send the Invoice invoice to customer">
      <incoming>PI1-SIC1</incoming>
      <outgoing>SIC1-XOR_JMPBB_CTR1_CFP1</outgoing>
    </task>
    <task id="CFP1" name="Check for Payment">
      <incoming>XOR_JMPBB_CTR1_CFP1-CFP1</incoming>
      <outgoing>CFP1-G3</outgoing>
    </task>
    <exclusiveGateway id="G3" name="G3">
      <incoming>CFP1-G3</incoming>
      <outgoing>G3-CO1</outgoing>
      <outgoing>G3-CTR1</outgoing>
    </exclusiveGateway>
    <task id="CO1" name="Closing Order">
      <incoming>G3-CO1</incoming>
      <outgoing>CO1-XORCLOSE30</outgoing>
    </task>
    <task id="CTR1" name="Checking the reminders">
      <incoming>G3-CTR1</incoming>
      <outgoing>CTR1-XOR_JMPAA_CTR1_CFP1</outgoing>
