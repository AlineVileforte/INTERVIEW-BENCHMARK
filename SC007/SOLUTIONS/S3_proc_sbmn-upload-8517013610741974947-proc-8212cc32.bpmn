<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_dc54dfcc-6a35-46c7-a6a4-5a58bd58288f" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-CC1</outgoing>
    </startEvent>
    <task id="CC1" name="Check Customer">
      <incoming>Default_init-CC1</incoming>
      <outgoing>CC1-G0</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>CC1-G0</incoming>
      <outgoing>G0-CPH1</outgoing>
      <outgoing>G0-CCT1</outgoing>
    </exclusiveGateway>
    <task id="CPH1" name="Check Payment History">
      <incoming>G0-CPH1</incoming>
      <outgoing>CPH1-XORCLOSE7</outgoing>
    </task>
    <task id="CCT1" name="Check Customer Type">
      <incoming>G0-CCT1</incoming>
      <outgoing>CCT1-XORCLOSE7</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE7" name="XORCLOSE7">
      <incoming>CPH1-XORCLOSE7</incoming>
      <incoming>CCT1-XORCLOSE7</incoming>
      <outgoing>XORCLOSE7-SCC1</outgoing>
    </exclusiveGateway>
    <task id="SCC1" name="Sending Confirmation to Customer">
      <incoming>XORCLOSE7-SCC1</incoming>
      <outgoing>SCC1-GRD1</outgoing>
    </task>
    <task id="GRD1" name="Getting ready for delivery">
      <incoming>SCC1-GRD1</incoming>
      <outgoing>GRD1-G3</outgoing>
    </task>
    <exclusiveGateway id="G3" name="G3">
      <incoming>GRD1-G3</incoming>
      <outgoing>G3-DM1</outgoing>
      <outgoing>G3-CNC1</outgoing>
    </exclusiveGateway>
    <task id="CNC1" name="Create New Customer">
      <incoming>G3-CNC1</incoming>
      <outgoing>CNC1-XORCLOSE14</outgoing>
    </task>
    <task id="DM1" name="Declining Message">
      <incoming>G3-DM1</incoming>
      <outgoing>DM1-XORCLOSE14</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE14" name="XORCLOSE14">
      <incoming>CNC1-XORCLOSE14</incoming>
      <incoming>DM1-XORCLOSE14</incoming>
      <outgoing>XORCLOSE14-Par15</outgoing>
    </exclusiveGateway>
    <parallelGateway id="Par15" name="PAR">
      <incoming>XORCLOSE14-Par15</incoming>
      <outgoing>Par15-CA1</outgoing>
      <outgoing>Par15-PTG1</outgoing>
    </parallelGateway>
    <task id="CA1" name="Check Availability">
      <incoming>Par15-CA1</incoming>
      <outgoing>CA1-G4</outgoing>
    </task>
    <task id="PTG1" name="Pack the Goods">
      <incoming>Par15-PTG1</incoming>
      <outgoing>PTG1-DTG1</outgoing>
    </task>
    <exclusiveGateway id="G4" name="G4">
      <incoming>CA1-G4</incoming>
      <outgoing>G4-PMG1</outgoing>
      <outgoing>G4-XORCLOSE24</outgoing>
    </exclusiveGateway>
    <task id="PMG1" name="Producing Missing Goods">
      <incoming>G4-PMG1</incoming>
      <outgoing>PMG1-XORCLOSE24</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE24" name="XORCLOSE24">
      <incoming>G4-XORCLOSE24</incoming>
      <incoming>PMG1-XORCLOSE24</incoming>
      <outgoing>XORCLOSE24-PARCLOSE28</outgoing>
    </exclusiveGateway>
    <task id="DTG1" name="Deliver the Goods">
      <incoming>PTG1-DTG1</incoming>
      <outgoing>DTG1-PI1</outgoing>
    </task>
    <task id="PI1" name="Preparing Invoice">
      <incoming>DTG1-PI1</incoming>
      <outgoing>PI1-PARCLOSE28</outgoing>
    </task>
    <parallelGateway id="PARCLOSE28" name="PARCLOSE28">
      <incoming>XORCLOSE24-PARCLOSE28</incoming>
      <incoming>PI1-PARCLOSE28</incoming>
      <outgoing>PARCLOSE28-SIC1</outgoing>
    </parallelGateway>
    <task id="SIC1" name="Send the Invoice invoice to customer">
      <incoming>PARCLOSE28-SIC1</incoming>
      <outgoing>SIC1-XOR_JMPBB_CTR1_CFP1</outgoing>
    </task>
    <task id="CFP1" name="Check for Payment">
      <incoming>XOR_JMPBB_CTR1_CFP1-CFP1</incoming>
      <outgoing>CFP1-G5</outgoing>
    </task>
    <exclusiveGateway id="G5" name="G5">
      <incoming>CFP1-G5</incoming>
      <outgoing>G5-CO1</outgoing>
      <outgoing>G5-CTR1</outgoing>
    </exclusiveGateway>
    <task id="CO1" name="Closing Order">
      <incoming>G5-CO1</incoming>
      <outgoing>CO1-XORCLOSE35</outgoing>
    </task>
    <task id="CTR1" name="Checking the reminders">
      <incoming>G5-CTR1</incoming>
      <outgoing>CTR1-XOR_JMPAA_CTR1_CFP1</outgoing>
    </task>
    <task id="DP1" name="Dunning Process">
      <incoming>XOR_JMPAA_CTR1_CFP1-DP1</incoming>
      <outgoing>DP1-XORCLOSE35</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE35" name="XORCLOSE35">
      <incoming>CO1-XORCLOSE35</incoming>
      <incoming>DP1-XORCLOSE35</incoming>
      <outgoing>XORCLOSE35-END</outgoing>
    </exclusiveGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>XORCLOSE35-END</incoming>
    </endEvent>
    <exclusiveGateway id="XOR_JMPAA_CTR1_CFP1" name="XOR_JMPAA_Checking the reminders">
      <incoming>CTR1-XOR_JMPAA_CTR1_CFP1</incoming>
      <outgoing>XOR_JMPAA_CTR1_CFP1-DP1</outgoing>
      <outgoing>XOR_JMPAA_CTR1_CFP1-XOR_JMPBB_CTR1_CFP1</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XOR_JMPBB_CTR1_CFP1" name="XOR_JMPBB_Check for Payment">
      <incoming>SIC1-XOR_JMPBB_CTR1_CFP1</incoming>
      <incoming>XOR_JMPAA_CTR1_CFP1-XOR_JMPBB_CTR1_CFP1</incoming>
      <outgoing>XOR_JMPBB_CTR1_CFP1-CFP1</outgoing>
    </exclusiveGateway>
