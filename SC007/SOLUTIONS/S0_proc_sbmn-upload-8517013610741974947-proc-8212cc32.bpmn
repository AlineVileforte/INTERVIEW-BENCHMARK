  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-CC1</outgoing>
      <outgoing>Par0-SCC1</outgoing>
    </parallelGateway>
    <task id="CC1" name="Check Customer">
      <incoming>Par0-CC1</incoming>
      <outgoing>CC1-G0</outgoing>
    </task>
    <task id="SCC1" name="Sending Confirmation to Customer">
      <incoming>Par0-SCC1</incoming>
      <outgoing>SCC1-Par10</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>CC1-G0</incoming>
      <outgoing>G0-CPH1</outgoing>
      <outgoing>G0-CCT1</outgoing>
    </exclusiveGateway>
    <task id="CPH1" name="Check Payment History">
      <incoming>G0-CPH1</incoming>
      <outgoing>CPH1-XORCLOSE14</outgoing>
    </task>
    <task id="CCT1" name="Check Customer Type">
      <incoming>G0-CCT1</incoming>
      <outgoing>CCT1-XORCLOSE14</outgoing>
    </task>
    <parallelGateway id="Par10" name="PAR">
      <incoming>SCC1-Par10</incoming>
      <outgoing>Par10-GRD1</outgoing>
      <outgoing>Par10-G1</outgoing>
    </parallelGateway>
    <task id="GRD1" name="Getting ready for delivery">
      <incoming>Par10-GRD1</incoming>
      <outgoing>GRD1-PTG1</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>Par10-G1</incoming>
      <outgoing>G1-CNC1</outgoing>
      <outgoing>G1-DM1</outgoing>
    </exclusiveGateway>
    <task id="CNC1" name="Create New Customer">
      <incoming>G1-CNC1</incoming>
      <outgoing>CNC1-XORCLOSE24</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE14" name="XORCLOSE14">
      <incoming>CPH1-XORCLOSE14</incoming>
      <incoming>CCT1-XORCLOSE14</incoming>
      <outgoing>XORCLOSE14-CA1</outgoing>
    </exclusiveGateway>
    <task id="PTG1" name="Pack the Goods">
      <incoming>GRD1-PTG1</incoming>
      <outgoing>PTG1-DTG1</outgoing>
    </task>
    <task id="CA1" name="Check Availability">
      <incoming>XORCLOSE14-CA1</incoming>
      <outgoing>CA1-G2</outgoing>
    </task>
    <task id="DTG1" name="Deliver the Goods">
      <incoming>PTG1-DTG1</incoming>
      <outgoing>DTG1-PI1</outgoing>
    </task>
    <task id="DM1" name="Declining Message">
      <incoming>G1-DM1</incoming>
      <outgoing>DM1-XORCLOSE24</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
      <incoming>CA1-G2</incoming>
      <outgoing>G2-PMG1</outgoing>
      <outgoing>G2-XORCLOSE25</outgoing>
    </exclusiveGateway>
    <task id="PMG1" name="Producing Missing Goods">
      <incoming>G2-PMG1</incoming>
      <outgoing>PMG1-XORCLOSE25</outgoing>
    </task>
    <task id="PI1" name="Preparing Invoice">
      <incoming>DTG1-PI1</incoming>
      <outgoing>PI1-SIC1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE24" name="XORCLOSE24">
      <incoming>CNC1-XORCLOSE24</incoming>
      <incoming>DM1-XORCLOSE24</incoming>
      <outgoing>XORCLOSE24-PARCLOSE29</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XORCLOSE25" name="XORCLOSE25">
      <incoming>G2-XORCLOSE25</incoming>
      <incoming>PMG1-XORCLOSE25</incoming>
      <outgoing>XORCLOSE25-PARCLOSE34</outgoing>
    </exclusiveGateway>
    <task id="SIC1" name="Send the Invoice invoice to customer">
      <incoming>PI1-SIC1</incoming>
      <outgoing>SIC1-XOR_JMPBB_CTR1_CFP1</outgoing>
    </task>
    <task id="CFP1" name="Check for Payment">
      <incoming>XOR_JMPBB_CTR1_CFP1-CFP1</incoming>
      <outgoing>CFP1-PARCLOSE29</outgoing>
    </task>
    <parallelGateway id="PARCLOSE29" name="PARCLOSE29">
      <incoming>XORCLOSE24-PARCLOSE29</incoming>
      <incoming>CFP1-PARCLOSE29</incoming>
      <outgoing>PARCLOSE29-CO1</outgoing>
    </parallelGateway>
    <task id="CO1" name="Closing Order">
      <incoming>PARCLOSE29-CO1</incoming>
      <outgoing>CO1-CTR1</outgoing>
    </task>
    <task id="CTR1" name="Checking the reminders">
      <incoming>CO1-CTR1</incoming>
      <outgoing>CTR1-XOR_JMPAA_CTR1_CFP1</outgoing>
    </task>
    <task id="DP1" name="Dunning Process">
      <incoming>XOR_JMPAA_CTR1_CFP1-DP1</incoming>
      <outgoing>DP1-PARCLOSE34</outgoing>
    </task>
    <parallelGateway id="PARCLOSE34" name="PARCLOSE34">
      <incoming>XORCLOSE25-PARCLOSE34</incoming>
      <incoming>DP1-PARCLOSE34</incoming>
      <outgoing>PARCLOSE34-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE34-END</incoming>
    </endEvent>
    <exclusiveGateway id="XOR_JMPAA_CTR1_CFP1" name="XOR_JMPAA_Checking the reminders">
      <incoming>CTR1-XOR_JMPAA_CTR1_CFP1</incoming>
      <outgoing>XOR_JMPAA_CTR1_CFP1-DP1</outgoing>
      <outgoing>XOR_JMPAA_CTR1_CFP1-XOR_JMPBB_CTR1_CFP1</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XOR_JMPBB_CTR1_CFP1" name="XOR_JMPBB_Check for Payment">
      <incoming>SIC1-XOR_JMPBB_CTR1_CFP1</incoming>
      <incoming>XOR_JMPAA_CTR1_CFP1-XOR_JMPBB_CTR1_CFP1</incoming>
      <outgoing>XOR_JMPBB_CTR1_CFP1-CFP1</outgoing>
    </exclusiveGateway>
