  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-SCC1</outgoing>
    </startEvent>
    <task id="SCC1" name="Sending Confirmation to Customer">
      <incoming>Default_init-SCC1</incoming>
      <outgoing>SCC1-Par1</outgoing>
    </task>
    <parallelGateway id="Par1" name="PAR">
      <incoming>SCC1-Par1</incoming>
      <outgoing>Par1-CC1</outgoing>
      <outgoing>Par1-GRD1</outgoing>
    </parallelGateway>
    <task id="CC1" name="Check Customer">
      <incoming>Par1-CC1</incoming>
      <outgoing>CC1-G1</outgoing>
    </task>
    <task id="GRD1" name="Getting ready for delivery">
      <incoming>Par1-GRD1</incoming>
      <outgoing>GRD1-Par5</outgoing>
    </task>
    <parallelGateway id="Par5" name="PAR">
      <incoming>GRD1-Par5</incoming>
      <outgoing>Par5-PTG1</outgoing>
      <outgoing>Par5-CCT1</outgoing>
    </parallelGateway>
    <exclusiveGateway id="G1" name="G1">
      <incoming>CC1-G1</incoming>
      <outgoing>G1-CPH1</outgoing>
      <outgoing>G1-XORCLOSE15</outgoing>
    </exclusiveGateway>
    <task id="CPH1" name="Check Payment History">
      <incoming>G1-CPH1</incoming>
      <outgoing>CPH1-XORCLOSE15</outgoing>
    </task>
    <task id="CCT1" name="Check Customer Type">
      <incoming>Par5-CCT1</incoming>
      <outgoing>CCT1-G2</outgoing>
    </task>
    <task id="PTG1" name="Pack the Goods">
      <incoming>Par5-PTG1</incoming>
      <outgoing>PTG1-DTG1</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
      <incoming>CCT1-G2</incoming>
      <outgoing>G2-CNC1</outgoing>
      <outgoing>G2-DM1</outgoing>
    </exclusiveGateway>
    <task id="CNC1" name="Create New Customer">
      <incoming>G2-CNC1</incoming>
      <outgoing>CNC1-XORCLOSE24</outgoing>
    </task>
    <task id="DTG1" name="Deliver the Goods">
      <incoming>PTG1-DTG1</incoming>
      <outgoing>DTG1-PI1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE15" name="XORCLOSE15">
      <incoming>G1-XORCLOSE15</incoming>
      <incoming>CPH1-XORCLOSE15</incoming>
      <outgoing>XORCLOSE15-CA1</outgoing>
    </exclusiveGateway>
    <task id="PI1" name="Preparing Invoice">
      <incoming>DTG1-PI1</incoming>
      <outgoing>PI1-SIC1</outgoing>
    </task>
    <task id="CA1" name="Check Availability">
      <incoming>XORCLOSE15-CA1</incoming>
      <outgoing>CA1-G3</outgoing>
    </task>
    <task id="DM1" name="Declining Message">
      <incoming>G2-DM1</incoming>
      <outgoing>DM1-XORCLOSE24</outgoing>
    </task>
    <task id="SIC1" name="Send the Invoice invoice to customer">
      <incoming>PI1-SIC1</incoming>
      <outgoing>SIC1-XOR_JMPBB_CTR1_CFP1</outgoing>
    </task>
    <exclusiveGateway id="G3" name="G3">
      <incoming>CA1-G3</incoming>
      <outgoing>G3-PMG1</outgoing>
      <outgoing>G3-XORCLOSE26</outgoing>
    </exclusiveGateway>
    <task id="PMG1" name="Producing Missing Goods">
      <incoming>G3-PMG1</incoming>
      <outgoing>PMG1-XORCLOSE26</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE24" name="XORCLOSE24">
      <incoming>CNC1-XORCLOSE24</incoming>
      <incoming>DM1-XORCLOSE24</incoming>
      <outgoing>XORCLOSE24-PARCLOSE32</outgoing>
    </exclusiveGateway>
    <task id="CFP1" name="Check for Payment">
      <incoming>XOR_JMPBB_CTR1_CFP1-CFP1</incoming>
      <outgoing>CFP1-Par27</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE26" name="XORCLOSE26">
      <incoming>G3-XORCLOSE26</incoming>
      <incoming>PMG1-XORCLOSE26</incoming>
      <outgoing>XORCLOSE26-PARCLOSE33</outgoing>
    </exclusiveGateway>
    <parallelGateway id="Par27" name="PAR">
      <incoming>CFP1-Par27</incoming>
      <outgoing>Par27-CO1</outgoing>
      <outgoing>Par27-CTR1</outgoing>
    </parallelGateway>
    <task id="CO1" name="Closing Order">
      <incoming>Par27-CO1</incoming>
      <outgoing>CO1-PARCLOSE30</outgoing>
    </task>
    <task id="CTR1" name="Checking the reminders">
      <incoming>Par27-CTR1</incoming>
      <outgoing>CTR1-XOR_JMPAA_CTR1_CFP1</outgoing>
    </task>
    <parallelGateway id="PARCLOSE30" name="PARCLOSE30">
      <incoming>CO1-PARCLOSE30</incoming>
      <incoming>XOR_JMPAA_CTR1_CFP1-PARCLOSE30</incoming>
      <outgoing>PARCLOSE30-DP1</outgoing>
    </parallelGateway>
    <task id="DP1" name="Dunning Process">
      <incoming>PARCLOSE30-DP1</incoming>
      <outgoing>DP1-PARCLOSE32</outgoing>
    </task>
    <parallelGateway id="PARCLOSE32" name="PARCLOSE32">
      <incoming>XORCLOSE24-PARCLOSE32</incoming>
      <incoming>DP1-PARCLOSE32</incoming>
      <outgoing>PARCLOSE32-PARCLOSE33</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE33" name="PARCLOSE33">
      <incoming>XORCLOSE26-PARCLOSE33</incoming>
      <incoming>PARCLOSE32-PARCLOSE33</incoming>
      <outgoing>PARCLOSE33-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE33-END</incoming>
    </endEvent>
    <exclusiveGateway id="XOR_JMPAA_CTR1_CFP1" name="XOR_JMPAA_Checking the reminders">
      <incoming>CTR1-XOR_JMPAA_CTR1_CFP1</incoming>
      <outgoing>XOR_JMPAA_CTR1_CFP1-PARCLOSE30</outgoing>
      <outgoing>XOR_JMPAA_CTR1_CFP1-XOR_JMPBB_CTR1_CFP1</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XOR_JMPBB_CTR1_CFP1" name="XOR_JMPBB_Check for Payment">
      <incoming>SIC1-XOR_JMPBB_CTR1_CFP1</incoming>
