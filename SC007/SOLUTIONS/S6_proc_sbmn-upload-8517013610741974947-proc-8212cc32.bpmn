  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-CC1</outgoing>
      <outgoing>Par0-SCC1</outgoing>
    </parallelGateway>
    <task id="CC1" name="Check Customer">
      <incoming>Par0-CC1</incoming>
      <outgoing>CC1-G0</outgoing>
    </task>
    <task id="SCC1" name="Sending Confirmation to Customer">
      <incoming>Par0-SCC1</incoming>
      <outgoing>SCC1-GRD1</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>CC1-G0</incoming>
      <outgoing>G0-CPH1</outgoing>
      <outgoing>G0-CCT1</outgoing>
    </exclusiveGateway>
    <task id="CPH1" name="Check Payment History">
      <incoming>G0-CPH1</incoming>
      <outgoing>CPH1-XORCLOSE10</outgoing>
    </task>
    <task id="GRD1" name="Getting ready for delivery">
      <incoming>SCC1-GRD1</incoming>
      <outgoing>GRD1-PTG1</outgoing>
