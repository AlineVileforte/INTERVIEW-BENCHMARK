    </exclusiveGateway>
    <task id="DP1" name="Dunning Process">
      <incoming>G6-DP1</incoming>
      <outgoing>DP1-XORCLOSE25</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE24" name="XORCLOSE24">
