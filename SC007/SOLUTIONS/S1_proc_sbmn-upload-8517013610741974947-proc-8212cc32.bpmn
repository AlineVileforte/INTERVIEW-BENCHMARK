  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-CC1</outgoing>
    </startEvent>
    <task id="CC1" name="Check Customer">
      <incoming>Default_init-CC1</incoming>
      <outgoing>CC1-SCC1</outgoing>
    </task>
    <task id="SCC1" name="Sending Confirmation to Customer">
      <incoming>CC1-SCC1</incoming>
      <outgoing>SCC1-GRD1</outgoing>
    </task>
    <task id="GRD1" name="Getting ready for delivery">
      <incoming>SCC1-GRD1</incoming>
      <outgoing>GRD1-Par3</outgoing>
    </task>
    <parallelGateway id="Par3" name="PAR">
      <incoming>GRD1-Par3</incoming>
      <outgoing>Par3-PTG1</outgoing>
      <outgoing>Par3-G2</outgoing>
    </parallelGateway>
    <task id="PTG1" name="Pack the Goods">
      <incoming>Par3-PTG1</incoming>
      <outgoing>PTG1-DTG1</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
      <incoming>Par3-G2</incoming>
      <outgoing>G2-CPH1</outgoing>
      <outgoing>G2-CCT1</outgoing>
    </exclusiveGateway>
    <task id="CPH1" name="Check Payment History">
      <incoming>G2-CPH1</incoming>
      <outgoing>CPH1-XORCLOSE12</outgoing>
    </task>
    <task id="DTG1" name="Deliver the Goods">
      <incoming>PTG1-DTG1</incoming>
      <outgoing>DTG1-PI1</outgoing>
    </task>
    <task id="PI1" name="Preparing Invoice">
      <incoming>DTG1-PI1</incoming>
      <outgoing>PI1-SIC1</outgoing>
    </task>
    <task id="CCT1" name="Check Customer Type">
      <incoming>G2-CCT1</incoming>
      <outgoing>CCT1-XORCLOSE12</outgoing>
    </task>
    <task id="SIC1" name="Send the Invoice invoice to customer">
      <incoming>PI1-SIC1</incoming>
      <outgoing>SIC1-XOR_JMPBB_CTR1_CFP1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE12" name="XORCLOSE12">
      <incoming>CPH1-XORCLOSE12</incoming>
      <incoming>CCT1-XORCLOSE12</incoming>
      <outgoing>XORCLOSE12-G3</outgoing>
    </exclusiveGateway>
    <task id="CFP1" name="Check for Payment">
      <incoming>XOR_JMPBB_CTR1_CFP1-CFP1</incoming>
      <outgoing>CFP1-G4</outgoing>
    </task>
    <exclusiveGateway id="G3" name="G3">
      <incoming>XORCLOSE12-G3</incoming>
      <outgoing>G3-DM1</outgoing>
      <outgoing>G3-CNC1</outgoing>
    </exclusiveGateway>
    <task id="CNC1" name="Create New Customer">
      <incoming>G3-CNC1</incoming>
      <outgoing>CNC1-XORCLOSE24</outgoing>
    </task>
    <exclusiveGateway id="G4" name="G4">
      <incoming>CFP1-G4</incoming>
      <outgoing>G4-CO1</outgoing>
      <outgoing>G4-CTR1</outgoing>
    </exclusiveGateway>
    <task id="CO1" name="Closing Order">
      <incoming>G4-CO1</incoming>
      <outgoing>CO1-XORCLOSE27</outgoing>
    </task>
    <task id="DM1" name="Declining Message">
      <incoming>G3-DM1</incoming>
      <outgoing>DM1-XORCLOSE24</outgoing>
    </task>
    <task id="CTR1" name="Checking the reminders">
      <incoming>G4-CTR1</incoming>
      <outgoing>CTR1-XOR_JMPAA_CTR1_CFP1</outgoing>
