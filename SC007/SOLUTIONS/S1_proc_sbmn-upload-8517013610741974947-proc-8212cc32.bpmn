    <exclusiveGateway id="G7" name="G7">
      <incoming>CA1-G7</incoming>
      <outgoing>G7-PMG1</outgoing>
      <outgoing>G7-XORCLOSE31</outgoing>
    </exclusiveGateway>
    <task id="PMG1" name="Producing Missing Goods">
      <incoming>G7-PMG1</incoming>
      <outgoing>PMG1-XORCLOSE31</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE31" name="XORCLOSE31">
      <incoming>G7-XORCLOSE31</incoming>
      <incoming>PMG1-XORCLOSE31</incoming>
      <outgoing>XORCLOSE31-PARCLOSE32</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE32" name="PARCLOSE32">
      <incoming>XORCLOSE27-PARCLOSE32</incoming>
      <incoming>XORCLOSE31-PARCLOSE32</incoming>
      <outgoing>PARCLOSE32-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE32-END</incoming>
    </endEvent>
    <exclusiveGateway id="XOR_JMPAA_CTR1_CFP1" name="XOR_JMPAA_Checking the reminders">
