<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_abe4b41f-7620-4194-a1d3-6ee57647477b" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-CI1</outgoing>
    </startEvent>
    <task id="CI1" name="Check Inventory">
      <incoming>Default_init-CI1</incoming>
      <outgoing>CI1-G0</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>CI1-G0</incoming>
      <outgoing>G0-IA1</outgoing>
      <outgoing>G0-INA1</outgoing>
    </exclusiveGateway>
    <task id="IA1" name="Inventory Available">
      <incoming>G0-IA1</incoming>
      <outgoing>IA1-G1</outgoing>
    </task>
    <task id="INA1" name="Inventory Not Available">
      <incoming>G0-INA1</incoming>
      <outgoing>INA1-RPO1</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>IA1-G1</incoming>
      <outgoing>G1-CPO1</outgoing>
      <outgoing>G1-XORCLOSE8</outgoing>
    </exclusiveGateway>
    <task id="CPO1" name="Confirm Purchase Order">
      <incoming>G1-CPO1</incoming>
      <outgoing>CPO1-XORCLOSE8</outgoing>
    </task>
    <task id="RPO1" name="Reject Purchase Order">
      <incoming>INA1-RPO1</incoming>
      <outgoing>RPO1-XORCLOSE13</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE8" name="XORCLOSE8">
      <incoming>G1-XORCLOSE8</incoming>
      <incoming>CPO1-XORCLOSE8</incoming>
      <outgoing>XORCLOSE8-G2</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="G2" name="G2">
      <incoming>XORCLOSE8-G2</incoming>
      <outgoing>G2-SP1</outgoing>
      <outgoing>G2-SI1</outgoing>
    </exclusiveGateway>
    <task id="SP1" name="Ship Product">
      <incoming>G2-SP1</incoming>
      <outgoing>SP1-XORCLOSE12</outgoing>
    </task>
    <task id="SI1" name="Send Invoice">
      <incoming>G2-SI1</incoming>
      <outgoing>SI1-XORCLOSE12</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE12" name="XORCLOSE12">
      <incoming>SP1-XORCLOSE12</incoming>
      <incoming>SI1-XORCLOSE12</incoming>
      <outgoing>XORCLOSE12-XORCLOSE13</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XORCLOSE13" name="XORCLOSE13">
      <incoming>RPO1-XORCLOSE13</incoming>
      <incoming>XORCLOSE12-XORCLOSE13</incoming>
      <outgoing>XORCLOSE13-END</outgoing>
    </exclusiveGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>XORCLOSE13-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-CI1" sourceRef="Default_init" targetRef="CI1"/>
    <sequenceFlow id="CI1-G0" sourceRef="CI1" targetRef="G0"/>
    <sequenceFlow id="G0-IA1" sourceRef="G0" targetRef="IA1"/>
